{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    { "src": "/CSS/(.*)", "dest": "/CSS/$1" },
    { "src": "/JS/(.*)", "dest": "/JS/$1" },
    { "src": "/IMG/(.*)", "dest": "/IMG/$1" },
    { "src": "/", "dest": "/api/index.php" },
    { "src": "/(.*)", "dest": "/api/$1.php" }
  ]
}